    "title": "SwiftMail - API Response Time Monitoring",
    "tags": ["swiftmail", "api", "latency"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Login API Response Time (ms)",
        "type": "timeseries",
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(swiftmail_api_request_duration_seconds_bucket{path=\"/v1/auth/login\"}[1m])) by (le)) * 1000",
            "legendFormat": "p50",
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "dfjtop5s2am0wd"
            }
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(swiftmail_api_request_duration_seconds_bucket{path=\"/v1/auth/login\"}[1m])) by (le)) * 1000",
            "legendFormat": "p95",
            "refId": "B",
            "datasource": {
              "type": "prometheus",
              "uid": "dfjtop5s2am0wd"
            }
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(swiftmail_api_request_duration_seconds_bucket{path=\"/v1/auth/login\"}[1m])) by (le)) * 1000",
            "legendFormat": "p99",
            "refId": "C",
            "datasource": {
              "type": "prometheus",
              "uid": "dfjtop5s2am0wd"
            }
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 0
        },
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10,
              "showPoints": "auto"
            },
            "unit": "ms"
          }
        },
        "options": {
          "tooltip": {
            "mode": "multi"
          },
          "legend": {
            "displayMode": "list",
            "placement": "bottom"
          }
