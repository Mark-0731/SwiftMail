# ===== SwiftMail Environment Configuration =====

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=10s
APP_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=swiftmail
DB_PASSWORD=swiftmail_dev
DB_NAME=swiftmail
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=5m

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ClickHouse
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_DATABASE=swiftmail
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# MinIO / S3
MINIO_ENDPOINT=localhost:9002
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=swiftmail-attachments
MINIO_USE_SSL=false

# JWT
JWT_ACCESS_SECRET=change-me-in-production-access-secret-key
JWT_REFRESH_SECRET=change-me-in-production-refresh-secret-key
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# SMTP Delivery Configuration
SMTP_HOST=localhost
SMTP_PORT=587
# Optional: SMTP Authentication (leave empty for local Postfix without auth)
SMTP_USERNAME=
SMTP_PASSWORD=

# Connection Pool Configuration (OPTIMIZED for high throughput)
SMTP_MIN_POOL_SIZE=20          # Increased from 10 (more pre-warmed connections)
SMTP_MAX_POOL_SIZE=500         # Increased from 100 (5x higher capacity)
SMTP_CONNECT_TIMEOUT=5s
SMTP_SEND_TIMEOUT=15s
SMTP_MAX_IDLE_TIME=2m
SMTP_MAX_CONN_AGE=10m
SMTP_MAX_CONN_USES=500

# ⚠️ CRITICAL: Retry Configuration
# SMTP_ENABLE_RETRIES controls application-level retry behavior
# 
# Set to FALSE (default) when using:
#   - Postfix relay (handles retries at transport layer)
#   - Any SMTP relay/MTA that manages its own retry queue
#   - Prevents duplicate retry systems
#
# Set to TRUE when using:
#   - Direct SMTP APIs (SendGrid API, AWS SES API, Mailgun API)
#   - SMTP providers that don't handle retries
#   - Testing/development without a relay
#
SMTP_ENABLE_RETRIES=false
SMTP_MAX_RETRIES=3

# Asynq Worker (Optimized Configuration)
WORKER_CONCURRENCY=50
WORKER_QUEUE_CRITICAL=8
WORKER_QUEUE_HIGH=5
WORKER_QUEUE_DEFAULT=2
WORKER_QUEUE_LOW=1
WORKER_STRICT_PRIORITY=true
WORKER_SHUTDOWN_TIMEOUT=30s

# Rate Limiting
RATE_LIMIT_PER_SEC=100
RATE_LIMIT_PER_DAY=50000

# Observability
OTEL_ENDPOINT=localhost:4318
PROMETHEUS_PORT=9091

# Stripe (Get your keys from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_PRICE_ID_STARTER=price_your_starter_plan_id
STRIPE_PRICE_ID_PRO=price_your_pro_plan_id
STRIPE_SUCCESS_URL=http://localhost:3000/billing/success
STRIPE_CANCEL_URL=http://localhost:3000/billing/cancel
